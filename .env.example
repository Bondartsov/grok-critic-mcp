# === grok-critic-mcp configuration ===
# Все переменные имеют префикс POLZA_ (pydantic-settings env_prefix)

# API ключ Polza.AI (обязательно)
POLZA_API_KEY=your-api-key-here

# Base URL Polza.AI API
POLZA_BASE_URL=https://polza.ai/api/v1

# Модель grok
POLZA_MODEL=x-ai/grok-4.20-multi-agent

# Количество агентов (4=быстро, 16=глубоко)
POLZA_AGENT_COUNT=16

# Timeout запроса в секундах
POLZA_TIMEOUT_SECONDS=300

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
POLZA_LOG_LEVEL=WARNING

# Куда пишутся логи (пусто = stderr)
POLZA_LOG_FILE=

# Стоимость за 1 миллион токенов (USD). 0 = не рассчитывать.
POLZA_PRICE_INPUT_PER_1M=2.6
POLZA_PRICE_OUTPUT_PER_1M=6.6
